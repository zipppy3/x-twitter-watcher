# ── Twitter Authentication ──
# Get these values from your browser DevTools -> Application -> Cookies -> x.com
TWITTER_AUTH_TOKEN=
TWITTER_CSRF_TOKEN=

# ── Telegram Notifications (Optional) ──
# 1. Message @BotFather on Telegram to create a bot and get a token
# 2. Start a chat with your bot, then get your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Telegram Auto-Upload Topics (Optional) ──
# Thread IDs (from the Topic URL in your Telegram Group)
TELEGRAM_AUDIO_THREAD_ID=
TELEGRAM_METADATA_THREAD_ID=

# ── Telegram 50MB Limit Bypass (Optional) ──
# To upload files larger than 50MB, run a Local Telegram Bot API Server via Docker.
# 1. Get your API ID and API Hash from https://my.telegram.org
# 2. Fill in the values below, then run: docker compose up -d
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_API_URL=http://127.0.0.1:8081
